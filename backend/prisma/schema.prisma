generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipes {
  id           Int          @id @default(autoincrement())
  title        String
  total_time   Int
  yields       Int
  ingredients  String[]
  instructions String[]
  image        String
  source       String
  Categories   Categories[]
}

model Categories {
  id       Int       @id @default(autoincrement())
  imageUrl String
  name     String
  Recipes  Recipes[]
}
